<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        *{
            margin: 0;
            padding: 0;
            overflow-x: hidden;
            box-sizing: border-box;
            font-family: Arial;
        }
        body{
            background-color: black;
            width: 100%;
            min-height: 100vh;
        }
        .head{
            display: flex;
            justify-content: center;
            flex-direction: column;
            align-items: center;
            padding: 10px;
            font-size: 60px; 
             font-weight: 1000;
            color: #fff;
        }
        .head h1{
            text-decoration: underline;
            transform: translateY(-300px);
            animation: scrollDown 1s ease-in-out 1s forwards;
        }
        @keyframes scrollDown {
            from{
                transform: translateY(-300px);
                filter: blur(20px);
                filter: drop-shadow(20px);
                filter: grayscale(20px);
                filter: contrast(20px);
                filter: brightness(20px);
                scale: calc(0.1);
            }
            to{
                transform: translateY(0px);
                filter: blur(0px);
                filter: drop-shadow(0px);
                filter: grayscale(0px);
                filter: contrast(0px);
                filter: brightness(0px);
                scale: calc(1);
                color: gold;
            }
        }
    </style>
</head>
<body>
    <div class="head">
    <h1>Post Manager</h1>
    
    <form action="http://localhost:3000/post/new" method="post">
        <input type="text" placeholder="Enter your username..." name="username">
        <textarea name="content">write something...</textarea>
        <button>submit</button>
    </form>
    </div>

</body>
</html>